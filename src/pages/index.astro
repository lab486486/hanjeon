---
import BaseLayout from '../layouts/BaseLayout.astro';
import BenefitRow from '../components/BenefitRow.astro';
import { daysUntil, getPublishedBenefits } from '../lib/benefits';

const benefits = await getPublishedBenefits();
const featured = benefits.filter((b) => b.data.featured).slice(0, 5);
const closingSoon = benefits
  .filter((b) => {
    const d = daysUntil(b.data.applyEnd);
    return d !== null && d >= 0 && d <= 45;
  })
  .slice(0, 5);
---

<BaseLayout title="한전넷" description="신청 가능한 전기요금·에너지 지원금을 빠르게 찾아보세요.">
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="hero__kicker">HANJEON.NET</span>
        <h1>한전넷</h1>
        <p class="hero__lead">
          전기요금 할인, 에너지바우처, 공동전기료, 전기차 지원까지.<br />
          한전넷을 즐겨찾기 해놓고 편하게 확인하세요!
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="/find/">신청 가능한 지원금 찾기</a>
          <a class="btn btn--ghost" href="/benefits/">전체 목록 보기</a>
        </div>
      </div>

      <aside class="hero__aside" aria-label="생활비 아껴주는 분야">
        <p class="hero__aside-label">💡 생활비 아껴주는 분야</p>
        <div class="hero__shortcuts">
          <a class="hero__shortcut" href="/benefits/?category=%EC%9A%94%EA%B8%88%ED%95%A0%EC%9D%B8">요금할인</a>
          <a class="hero__shortcut" href="/benefits/?category=%EB%B0%94%EC%9A%B0%EC%B2%98">바우처</a>
          <a class="hero__shortcut" href="/benefits/?category=%EA%B3%B5%EB%8F%99%EC%A0%84%EA%B8%B0%EB%A3%8C">공동전기료</a>
          <a class="hero__shortcut" href="/benefits/?category=%EC%A0%84%EA%B8%B0%EC%B0%A8">전기차</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <div>
          <h2>핵심 혜택</h2>
          <p>검색·신청이 많은 전기·에너지 지원부터</p>
        </div>
        <a href="/guides/">가이드 보기 →</a>
      </div>
      <div class="benefit-list">
        {featured.map((benefit) => <BenefitRow benefit={benefit} />)}
      </div>
    </div>
  </section>

  {
    closingSoon.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section__head">
            <div>
              <h2>마감 임박</h2>
              <p>신청 종료일이 가까운 항목</p>
            </div>
          </div>
          <div class="benefit-list">
            {closingSoon.map((benefit) => (
              <BenefitRow benefit={benefit} />
            ))}
          </div>
        </div>
      </section>
    )
  }

</BaseLayout>
