---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="가이드" description="전기요금·에너지 지원 핵심 안내" path="/guides/">
  <section class="section" style="padding-top: 2.5rem;">
    <div class="container">
      <div class="section__head">
        <div>
          <h2>가이드</h2>
          <p>자주 찾는 전기·에너지 혜택을 쉽게 정리했습니다.</p>
        </div>
      </div>
      <div class="benefit-list">
        {
          guides.map((guide) => (
            <a class="benefit-row" href={`/guides/${guide.id}/`}>
              <div>
                <h3>{guide.data.title}</h3>
                <p class="benefit-row__summary">{guide.data.description}</p>
              </div>
              <div class="benefit-row__side">
                <span class="chip">업데이트 {guide.data.updatedAt}</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
